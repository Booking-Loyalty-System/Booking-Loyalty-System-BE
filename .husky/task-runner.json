{
   "$schema": "https://alirezanet.github.io/Husky.Net/schema.json",
   "variables": [
      {
         "name": "root-dir",
         "command": "bash",
         "args": ["-c", "pwd"]
      }
   ],
   "tasks": [
      {
         "name": "commit-message-linter",
         "command": "dotnet",
         "args": ["husky", "exec", ".husky/csx/commit-lint.csx", "--args", "${args}"]
      },
      {
         "name": "update-version",
         "command": "dotnet",
         "args" :["husky", "exec", ".husky/csx/version-updater.csx", "--args", "${args}"]
      },
      {
         "name": "check-branch-name",
         "command": "dotnet",
         "args": ["husky", "exec", ".husky/csx/check-branch-name.csx"],
         "group": "pre-push"
      },
      {
         "name": "echo-staged-files",
         "pathMode": "absolute",
         "command": "echo",
         "group": "pre-commit",
         "args": ["${staged}"]
      }
   ]
}